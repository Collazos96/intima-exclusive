{
  "name": "intima-exclusive",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:worker": "wrangler dev --env dev",
    "dev:worker:remote": "wrangler dev --env dev --remote",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 execute intima-exclusive-db --local --file=migrations/0001_rate_limits.sql",
    "db:migrate:remote": "wrangler d1 execute intima-exclusive-db --remote --file=migrations/0001_rate_limits.sql"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.99.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.1",
    "sonner": "^2.0.7",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.4",
    "wrangler": "^4.82.2"
  }
}
