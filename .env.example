# Copia este archivo como .env para desarrollo local

# --- OPCIÓN A (recomendada): worker local ---
# Ejecuta en otra terminal: npm run dev:worker
VITE_API_URL=http://localhost:8787

# --- OPCIÓN B: worker remoto de producción ---
# (requiere que tu IP no tenga CORS bloqueado; solo si pruebas contra prod)
# VITE_API_URL=https://intima-exclusive-api.juanfecolla.workers.dev

# --- Opcional: activa SOLO si compraste Cloudflare Image Transformations ---
# VITE_ENABLE_IMAGE_TRANSFORMS=true
