# Cloudflare Pages _headers
# Docs: https://developers.cloudflare.com/pages/configuration/headers/

# Assets con hash en el nombre -> inmutables durante 1 año
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# robots.txt, sitemap, llms.txt -> cache corto (contenido puede cambiar)
/robots.txt
  Cache-Control: public, max-age=3600
/llms.txt
  Cache-Control: public, max-age=3600

# HTML -> no-cache (SPA con meta dinámicos)
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Seguridad global
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
